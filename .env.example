# ------------------------------------------------------------------------------
# Enterprise Agentic Trading System - Environment Template (.env.example)
# Copy this file to '.env' and fill in your keys.
# ------------------------------------------------------------------------------

# Gemini API Key (Required for LLM Quantitative Analysis & Critique Loops)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Alpaca Paper Trading API Credentials (Optional)
# If missing or containing placeholders, the system automatically falls back to 
# a self-contained Black-Scholes pricing model and mock trading simulator.
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# LangSmith Observability & Tracing Configuration (Optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT="agentic-trading-praxis"
